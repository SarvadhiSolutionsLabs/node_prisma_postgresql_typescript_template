{
  "name": "node-ts-prisma-backend-skeleton",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise-ready Node.js/TypeScript/Express/Prisma backend skeleton aligned with clario-backend patterns.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:local": "cross-env APP_ENV=local NODE_ENV=development npm run build",
    "build:dev": "cross-env APP_ENV=dev NODE_ENV=development npm run build",
    "build:staging": "cross-env APP_ENV=staging NODE_ENV=production npm run build",
    "build:prod": "cross-env APP_ENV=production NODE_ENV=production npm run build",
    "build:interactive": "tsx scripts/build-interactive.ts",
    "start": "node dist/index.js",
    "lint": "eslint --config .eslintrc.cjs \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --config .eslintrc.cjs \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier \"{src,scripts,prisma}/**/*.{ts,js,json,md}\" --write",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "winston": "^3.13.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prisma": "^6.0.0",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
